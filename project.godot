;   param=value ; assign values to parameters

config_version=5

[application]

config/name="metroidvania-jam"
run/main_scene="uid://b3lqgt7u4lvcp"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GUIDE="*res://addons/guide/guide.gd"

[display]

window/size/viewport_width=854
window/size/viewport_height=480
window/size/resizable=false
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_state_charts/plugin.cfg", "res://addons/guide/plugin.cfg", "res://addons/licenses/plugin.cfg")
